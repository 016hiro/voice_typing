{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "swiftlint lint --quiet 2>&1 || true",
            "statusMessage": "SwiftLint..."
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/swift-precheck.sh",
            "statusMessage": "Swift compile + unit tests (CI mirror)..."
          }
        ]
      }
    ]
  }
}
