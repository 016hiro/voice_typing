.DS_Store
.build/
build/
*.xcodeproj
.swiftpm/
*.log
# .claude/ — track shared project config (settings.json, hooks/) but ignore
# user-local / runtime / non-portable bits. The hooks under .claude/hooks/
# are the project's CI-mirror Stop hook gate — must be committed so the gate
# applies across machines and fresh clones, not just on the original dev's box.
.claude/skills/
.claude/scheduled_tasks.lock
.claude/settings.local.json
# Intermediate iconset generated by Scripts/generate_icons.swift — the
# compiled AppIcon.icns is the one that ships.
Resources/AppIcon.iconset/
__pycache__/
docs/devlog/analysis/
# Throwaway venv used by Scripts/perf/ (mlx-lm + huggingface_hub for the
# resource baseline audit). Big (~750 MB), machine-specific, recreatable:
#   python3 -m venv .venv-perf && .venv-perf/bin/pip install mlx-lm hf_transfer
.venv-perf/
# v0.6.0 Sparkle: never commit private update-signing keys. The Keychain
# is the authoritative store; `generate_keys -x` produces export files here
# only for password-manager backup.
*.sparkle_key
sparkle_private_key.txt
